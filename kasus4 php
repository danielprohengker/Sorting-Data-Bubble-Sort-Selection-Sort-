// selection sort
$harga = [50000, 15000, 80000, 35000, 20000];
$n = count($harga);
for ($i = 0; $i < $n; $i++) {
    $min_idx = $i;
    for ($j = $i+1; $j < $n; $j++) {
        if ($harga[$j] < $harga[$min_idx]) $min_idx = $j;
    }
    $temp = $harga[$i]; $harga[$i] = $harga[$min_idx]; $harga[$min_idx] = $temp;
}
echo "Harga Kartu: " . implode(", ", $harga);
