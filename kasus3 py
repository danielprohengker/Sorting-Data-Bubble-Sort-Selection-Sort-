# bubble sort
data = [10, 11, 12, 13, 14, 15, 16, 17, 19, 18]
n = len(data)
for i in range(n):
    swapped = False
    for j in range(0, n-i-1):
        if data[j] > data[j+1]:
            data[j], data[j+1] = data[j+1], data[j]
            swapped = True
    if not swapped: break 
print(f"Data Terurut: {data}")
