// bubble sort
$tinggi = [150, 170, 155, 160, 145];
$n = count($tinggi);
for ($i = 0; $i < $n; $i++) {
    for ($j = 0; $j < $n - $i - 1; $j++) {
        if ($tinggi[$j] > $tinggi[$j+1]) {
            $temp = $tinggi[$j];
            $tinggi[$j] = $tinggi[$j+1];
            $tinggi[$j+1] = $temp;
        }
    }
}
echo "Hasil Akhir: [" . implode(", ", $tinggi) . "]";
