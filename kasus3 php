// bubble sort
$data = [10, 11, 12, 13, 14, 15, 16, 17, 19, 18];
$n = count($data);
for ($i = 0; $i < $n; $i++) {
    $swapped = false;
    for ($j = 0; $j < $n - $i - 1; $j++) {
        if ($data[$j] > $data[$j+1]) {
            $temp = $data[$j]; $data[$j] = $data[$j+1]; $data[$j+1] = $temp;
            $swapped = true;
        }
    }
    if (!$swapped) break;
}
echo "Data Terurut: " . implode(", ", $data);
